{
  "name": "@zchazc/nbcb-provider",
  "version": "1.0.0",
  "description": "OpenCode plugin that provides a custom LLM provider with periodic token refresh",
  "main": "src/index.ts",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "dev": "bun run --watch src/index.ts"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "provider",
    "token-refresh"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
